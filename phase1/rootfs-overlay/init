#!/bin/sh
# /init — PID 1 when kernel boots from initramfs
# Mounts essential filesystems, writes /etc/inittab, hands off to BusyBox init.
# Text login on tty1 — user runs `startx` for GUI.

export PATH=/sbin:/bin:/usr/bin:/usr/sbin:/usr/local/bin

# ── Mount virtual filesystems ─────────────────────────────────────────────────
mount -t proc     none /proc    2>/dev/null
mount -t sysfs    none /sys     2>/dev/null
mount -t devtmpfs none /dev     2>/dev/null || mdev -s 2>/dev/null
mkdir -p /dev/pts /dev/shm
mount -t devpts   devpts /dev/pts 2>/dev/null
mount -t tmpfs    tmpfs  /dev/shm 2>/dev/null
mount -t tmpfs    tmpfs  /tmp     2>/dev/null

# Seed /dev/null in case devtmpfs failed
[ -c /dev/null ] || mknod -m 666 /dev/null c 1 3

# ── Redirect console to tty1 ──────────────────────────────────────────────────
exec </dev/tty1 >/dev/tty1 2>/dev/tty1

# ── Loopback ──────────────────────────────────────────────────────────────────
ip link set lo up 2>/dev/null || true

# ── Write inittab (text login only — user types `startx` for X11) ────────────
cat > /etc/inittab << 'INITTAB'
# Flynn OS inittab
::sysinit:/etc/init.d/rcS
::once:/usr/local/bin/flynn-network-init
::once:/usr/sbin/dropbear -R -p 22 2>/dev/null
tty1::respawn:/sbin/getty -n -l /usr/local/bin/flynn-autologin 38400 tty1
tty2::respawn:/sbin/getty 38400 tty2
tty3::respawn:/sbin/getty 38400 tty3
::ctrlaltdel:/sbin/reboot
::shutdown:/sbin/swapoff -a
INITTAB

# ── Auto-login script ─────────────────────────────────────────────────────────
cat > /usr/local/bin/flynn-autologin << 'AUTOLOGIN'
#!/bin/sh
# Auto-login as root, show Flynn banner, then drop to shell
export HOME=/root
export USER=root
export LOGNAME=root
cd /root
exec /usr/local/bin/flynn-ui
AUTOLOGIN
chmod +x /usr/local/bin/flynn-autologin

# ── Hand off to BusyBox init ──────────────────────────────────────────────────
if [ -x /sbin/init ]; then
    exec /sbin/init
elif [ -x /bin/sh ]; then
    echo "Flynn OS: no /sbin/init, dropping to shell"
    exec /bin/sh
else
    echo "PANIC: no init and no shell"
    while true; do sleep 99; done
fi
