#!/bin/sh
# /init — PID 1 when kernel boots from initramfs
# Mounts essential filesystems, then hands off to BusyBox init

export PATH=/sbin:/bin:/usr/bin:/usr/sbin:/usr/local/bin

# Mount essential virtual filesystems
mount -t proc     none /proc  2>/dev/null
mount -t sysfs    none /sys   2>/dev/null
mount -t devtmpfs none /dev   2>/dev/null || mdev -s 2>/dev/null
mkdir -p /dev/pts /dev/shm
mount -t devpts   devpts /dev/pts 2>/dev/null
mount -t tmpfs    tmpfs  /dev/shm 2>/dev/null

# Seed /dev/null in case devtmpfs failed
[ -c /dev/null ] || mknod -m 666 /dev/null c 1 3

# Console — redirect stdin/stdout/stderr to tty0
exec </dev/tty0 >/dev/tty0 2>/dev/tty0

# Bring up loopback
ip link set lo up 2>/dev/null || true

# Hand off to BusyBox init (reads /etc/inittab)
# Falls back to an interactive shell if init isn't available
if [ -x /sbin/init ]; then
    exec /sbin/init
elif [ -x /bin/sh ]; then
    echo "Flynn OS: fallback to shell"
    exec /bin/sh
else
    echo "PANIC: no init and no shell found"
    while true; do sleep 99; done
fi
