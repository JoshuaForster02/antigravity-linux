#!/bin/sh
# Flynn OS — Openbox autostart

# Audio
pipewire &
sleep 0.3
wireplumber &

# Boot chime (once per session)
/usr/local/bin/flynn-boot-chime &

# Compositor — TRON cyan glow on window borders
picom --config /root/.config/picom/picom.conf --daemon 2>/dev/null &

# TRON wallpaper (static draw, fast)
/usr/local/bin/flynn-wallpaper 2>/dev/null || xsetroot -solid "#000810"

# Notifications (TRON-styled dunst)
dunst &

# Panel (tint2 — TRON-themed taskbar at bottom)
tint2 -c /root/.config/tint2/tint2rc 2>/dev/null &

# Network manager tray
nm-applet 2>/dev/null &

# Flynn daemon started via systemd (flynn-daemon.service)

# Main Flynn terminal — opens automatically with TRON splash
sleep 0.8
xterm \
    -bg "#000810" -fg "#00E5FF" \
    -fa "JetBrains Mono" -fs 12 \
    -title "Flynn OS — The Grid" \
    -geometry 112x32+60+60 \
    -bd "#00E5FF" -bw 1 \
    -e /usr/local/bin/flynn-ui &
