# Flynn OS — Lock screen · Ice Grid
image=/root/.config/sway/tron-bg.png
scaling=fill
color=0a0b10

font=Noto Sans
font-size=14

clock
timestr=%H:%M
datestr=%A, %d %B

indicator
indicator-radius=86
indicator-thickness=3
indicator-idle-visible

# Ring — thin ice ring, red on wrong
ring-color=22303d
ring-ver-color=9fdcf5
ring-wrong-color=e5606c
ring-clear-color=d9b96a

# Inside
inside-color=0a0b10cc
inside-ver-color=0a0b10cc
inside-wrong-color=1d1014cc
inside-clear-color=0a0b10cc

# Text
text-color=e2eaf0
text-ver-color=c4ecfb
text-wrong-color=f08791
text-clear-color=e8cd8c

# Key feedback
key-hl-color=9fdcf5
bs-hl-color=e5606c
separator-color=00000000

# Layout
layout-bg-color=0a0b10cc
layout-text-color=98a4b0

fade-in=0.2
show-failed-attempts
ignore-empty-password
