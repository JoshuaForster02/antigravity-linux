# Flynn OS — Swaylock TRON lockscreen
# Uses pre-generated TRON grid wallpaper as background
image=/root/.config/sway/tron-bg.png
scaling=fill
color=00050f

font=JetBrains Mono
font-size=13
letter-spacing=4

# Ring — thin, subtle TRON circle
indicator-radius=60
indicator-thickness=3
ring-color=00395266
ring-ver-color=00e5ff
ring-clear-color=002233
ring-wrong-color=ff3322

# Highlight flash on keypress
key-hl-color=00e5ff88
bs-hl-color=003344
separator-color=00000000

# Text labels
text-color=00a8c8aa
text-ver-color=00e5ff
text-clear-color=004455
text-wrong-color=ff4433

# Interior of circle
inside-color=00050fbb
inside-ver-color=000c1acc
inside-clear-color=00050fbb
inside-wrong-color=150003bb

line-uses-ring
grace=2
fade-in=0.2
indicator
