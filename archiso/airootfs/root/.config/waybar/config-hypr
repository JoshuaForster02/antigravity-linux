{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 0,
  "exclusive": true,
  "modules-left": [
    "custom/logo",
    "hyprland/workspaces",
    "custom/mode"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "custom/pomodoro",
    "custom/anki",
    "idle_inhibitor",
    "cpu",
    "memory",
    "temperature",
    "battery",
    "pulseaudio",
    "bluetooth",
    "network",
    "tray",
    "custom/power"
  ],
  "custom/logo": {
    "format": "◎  Flynn OS",
    "tooltip-format": "App Launcher  (Super+D)",
    "on-click": "fuzzel"
  },
  "hyprland/workspaces": {
    "all-outputs": true,
    "format": "{icon}",
    "format-icons": { "1": "GRID", "2": "STUDY", "3": "ANKI", "4": "GAME", "5": "SYS" },
    "persistent-workspaces": { "*": 5 }
  },
  "custom/mode": {
    "exec": "bash -c 'm=$(cat /tmp/flynnos-mode 2>/dev/null||echo study); [ \"$m\" = game ] && echo \" Game\" || echo \" Study\"'",
    "interval": 2,
    "tooltip-format": "Game / Study mode  (Super+G)",
    "on-click": "/usr/local/bin/game-mode-switch.sh toggle"
  },
  "clock": {
    "format": "{:%a %d %b   %H:%M}",
    "format-alt": "{:%Y-%m-%d   %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "interval": 1
  },
  "custom/anki": {
    "exec": "/usr/local/bin/flynn-anki-due",
    "interval": 60,
    "tooltip-format": "Anki cards due — click to open",
    "on-click": "bash -c 'anki 2>/dev/null || true'"
  },
  "custom/pomodoro": {
    "exec": "/usr/local/bin/flynn-pomodoro status",
    "interval": 5,
    "tooltip-format": "Pomodoro — click: start/stop · right-click: break",
    "on-click": "/usr/local/bin/flynn-pomodoro toggle",
    "on-click-right": "/usr/local/bin/flynn-pomodoro break"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "",
      "deactivated": ""
    },
    "tooltip-format-activated": "Screen stays awake",
    "tooltip-format-deactivated": "Auto-lock active"
  },
  "cpu": {
    "format": " {usage}%",
    "interval": 3,
    "tooltip-format": "CPU {usage}%",
    "on-click": "foot -e btop",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "memory": {
    "format": " {percentage}%",
    "interval": 5,
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
    "on-click": "foot -e btop"
  },
  "temperature": {
    "critical-threshold": 85,
    "format": " {temperatureC}°",
    "tooltip-format": "Thermal {temperatureC}°C",
    "interval": 5
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-icons": ["", "", "", "", ""],
    "interval": 20
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "",
    "format-icons": { "default": ["", "", ""] },
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +3%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -3%"
  },
  "bluetooth": {
    "format": "",
    "format-connected": " {num_connections}",
    "format-disabled": "",
    "format-off": "",
    "tooltip-format": "{device_alias}",
    "on-click": "/usr/local/bin/flynn-bluetooth",
    "on-click-right": "blueman-manager"
  },
  "network": {
    "format-wifi": " {signalStrength}%",
    "format-ethernet": "",
    "format-disconnected": "",
    "tooltip-format": "{ifname}  {ipaddr}/{cidr}",
    "on-click": "/usr/local/bin/flynn-wifi",
    "on-click-right": "nm-connection-editor",
    "interval": 10
  },
  "tray": {
    "spacing": 8,
    "icon-size": 15
  },
  "custom/power": {
    "format": "",
    "tooltip-format": "Power  (Super+Escape)",
    "on-click": "/usr/local/bin/flynn-power"
  }
}
