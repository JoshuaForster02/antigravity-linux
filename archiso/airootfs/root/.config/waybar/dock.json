{
  "layer": "top",
  "position": "bottom",
  "height": 52,
  "margin-bottom": 8,
  "margin-left": 200,
  "margin-right": 200,
  "exclusive": true,
  "name": "dock",
  "passthrough": false,
  "modules-center": [
    "custom/term",
    "custom/launcher",
    "custom/files",
    "custom/browser",
    "custom/anki",
    "custom/steam",
    "custom/sep1",
    "wlr/taskbar",
    "custom/sep2",
    "custom/mode",
    "custom/wifi",
    "custom/volume",
    "custom/settings",
    "custom/help",
    "custom/lock"
  ],
  "custom/term": {
    "format": "",
    "tooltip-format": "Terminal  (Super+Return)",
    "on-click": "foot --app-id=flynn-ui -e /usr/local/bin/flynn-ui"
  },
  "custom/launcher": {
    "format": "",
    "tooltip-format": "App Launcher  (Super+D)",
    "on-click": "fuzzel"
  },
  "custom/files": {
    "format": "",
    "tooltip-format": "Files",
    "on-click": "thunar"
  },
  "custom/browser": {
    "format": "",
    "tooltip-format": "Notion  ·  right-click: Amboss",
    "on-click": "/usr/local/bin/flynn-browser https://notion.so --title Notion",
    "on-click-right": "/usr/local/bin/flynn-browser https://amboss.com --title Amboss"
  },
  "custom/anki": {
    "format": "",
    "tooltip-format": "Anki  (Super+A)",
    "on-click": "bash -c 'anki 2>/dev/null || /usr/local/bin/flynn-browser http://localhost:8765 --title Anki'"
  },
  "custom/steam": {
    "format": "",
    "tooltip-format": "Steam  ·  right-click: GameMode",
    "on-click": "bash -c 'command -v steam >/dev/null && steam -bigpicture || /usr/local/bin/flynn-notify error \"Steam not installed — run flynn-setup\"'",
    "on-click-right": "/usr/local/bin/game-mode-switch.sh toggle"
  },
  "custom/sep1": {
    "format": "│",
    "tooltip": false
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 22,
    "icon-theme": "Papirus-Dark",
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "on-click-right": "minimize"
  },
  "custom/sep2": {
    "format": "│",
    "tooltip": false
  },
  "custom/mode": {
    "format": "",
    "tooltip-format": "Game / Study mode  (Super+G)",
    "on-click": "/usr/local/bin/game-mode-switch.sh toggle",
    "on-click-right": "/usr/local/bin/flynn-study"
  },
  "custom/wifi": {
    "format": "",
    "tooltip-format": "Wi-Fi  ·  right-click: connection editor",
    "on-click": "/usr/local/bin/flynn-wifi",
    "on-click-right": "nm-connection-editor"
  },
  "custom/volume": {
    "format": "",
    "tooltip-format": "Volume  ·  scroll to adjust  ·  click: mixer",
    "on-click": "pavucontrol",
    "on-scroll-up": "bash -c 'pactl set-sink-volume @DEFAULT_SINK@ +5% && /usr/local/bin/flynn-notify volume'",
    "on-scroll-down": "bash -c 'pactl set-sink-volume @DEFAULT_SINK@ -5% && /usr/local/bin/flynn-notify volume'",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },
  "custom/settings": {
    "format": "",
    "tooltip-format": "Settings  (Super+,)",
    "on-click": "/usr/local/bin/flynn-settings"
  },
  "custom/help": {
    "format": "",
    "tooltip-format": "All shortcuts & help  (Super+?)",
    "on-click": "foot --app-id=flynn-help -e bash -c 'cat /usr/local/share/flynn-help.txt; echo; read -p \"  [Enter] to close\"'"
  },
  "custom/lock": {
    "format": "",
    "tooltip-format": "Power  ·  right-click: Lock",
    "on-click": "/usr/local/bin/flynn-power",
    "on-click-right": "/usr/local/bin/flynn-lock"
  }
}
