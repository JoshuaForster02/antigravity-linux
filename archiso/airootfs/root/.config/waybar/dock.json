{
  "layer": "bottom",
  "position": "bottom",
  "height": 36,
  "margin-bottom": 0,
  "exclusive": true,
  "name": "dock",
  "passthrough": false,
  "modules-center": [
    "custom/term",
    "custom/launcher",
    "custom/files",
    "custom/browser",
    "custom/anki",
    "custom/mode",
    "custom/sep1",
    "custom/steam",
    "custom/sep2",
    "custom/volume",
    "custom/wifi",
    "custom/settings",
    "custom/lock"
  ],
  "custom/term": {
    "format": "TERM",
    "tooltip": "Terminal  (Super+Return)",
    "on-click": "foot --app-id=flynn-ui -e /usr/local/bin/flynn-ui"
  },
  "custom/launcher": {
    "format": "LAUNCH",
    "tooltip": "App Launcher  (Super+D)",
    "on-click": "fuzzel"
  },
  "custom/files": {
    "format": "FILES",
    "tooltip": "File Manager",
    "on-click": "thunar"
  },
  "custom/browser": {
    "format": "NET",
    "tooltip": "Notion  |  right-click: Amboss",
    "on-click": "/usr/local/bin/flynn-browser https://notion.so --title Notion",
    "on-right-click": "/usr/local/bin/flynn-browser https://amboss.com --title Amboss"
  },
  "custom/anki": {
    "format": "ANKI",
    "tooltip": "Anki  (Super+A)",
    "on-click": "anki 2>/dev/null || /usr/local/bin/flynn-browser http://localhost:8765 --title Anki"
  },
  "custom/sep1": {
    "format": " ",
    "tooltip": false
  },
  "custom/steam": {
    "format": "GAME",
    "tooltip": "Steam  |  right-click: toggle GameMode",
    "on-click": "bash -c 'command -v steam >/dev/null && steam -bigpicture || foot -e bash -c \"Run flynn-setup for Steam\"; read'",
    "on-right-click": "/usr/local/bin/game-mode-switch.sh toggle"
  },
  "custom/sep2": {
    "format": " ",
    "tooltip": false
  },
  "custom/volume": {
    "format": "AUD",
    "tooltip": "Volume  |  scroll: adjust  |  click: mixer",
    "on-click": "pavucontrol",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "on-right-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },
  "custom/wifi": {
    "format": "LINK",
    "tooltip": "Network  |  click: nmtui  |  right-click: settings",
    "on-click": "foot -e nmtui",
    "on-right-click": "nm-connection-editor"
  },
  "custom/settings": {
    "format": "CFG",
    "tooltip": "Settings  (Super+,)",
    "on-click": "foot --app-id=flynn-settings -e /usr/local/bin/flynn-settings",
    "on-right-click": "nm-connection-editor"
  },
  "custom/lock": {
    "format": "PWR",
    "tooltip": "Power menu  |  right-click: Lock",
    "on-click": "/usr/local/bin/flynn-power",
    "on-right-click": "/usr/local/bin/flynn-lock"
  },
  "custom/mode": {
    "format": "MODE",
    "tooltip": "Game / Study mode  (Super+G)",
    "on-click": "/usr/local/bin/game-mode-switch.sh toggle",
    "on-right-click": "/usr/local/bin/flynn-study"
  }
}
