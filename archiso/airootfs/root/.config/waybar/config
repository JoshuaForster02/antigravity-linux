{
  "layer": "top",
  "position": "bottom",
  "height": 40,
  "spacing": 0,
  "margin-bottom": 0,

  "modules-left":   ["custom/logo", "sway/workspaces", "sway/mode"],
  "modules-center": ["custom/clock-display"],
  "modules-right":  ["cpu", "memory", "pulseaudio", "network", "custom/session"],

  "custom/logo": {
    "format": "  ⬡ FLYNN OS  ",
    "tooltip": false,
    "on-click": "exec /usr/local/bin/flynn-dashboard"
  },

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}",
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "focused": "",
      "urgent": "⚠"
    }
  },

  "sway/mode": {
    "format": "  {}  "
  },

  "custom/clock-display": {
    "exec": "date +'%H:%M:%S  ·  %a %d.%m.%Y'",
    "interval": 1,
    "format": "{}",
    "tooltip": false
  },

  "cpu": {
    "format": "CPU  {usage:02}%",
    "interval": 2,
    "tooltip": false,
    "states": { "warning": 70, "critical": 90 }
  },

  "memory": {
    "format": "MEM  {percentage:02}%",
    "interval": 5,
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
  },

  "pulseaudio": {
    "format": "VOL  {volume:03}%",
    "format-muted": "VOL  ---",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%",
    "tooltip": false
  },

  "network": {
    "format-wifi":         "NET  {signalStrength}%",
    "format-ethernet":     "ETH  ▲",
    "format-disconnected": "NET  ---",
    "tooltip-format": "{ifname}  {ipaddr}",
    "on-click": "nm-connection-editor",
    "interval": 10
  },

  "custom/session": {
    "format": "  ⏻  ",
    "tooltip": false,
    "on-click": "swaymsg exit"
  }
}
