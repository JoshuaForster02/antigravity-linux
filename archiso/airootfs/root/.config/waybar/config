{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 0,
  "exclusive": true,

  "modules-left":   ["custom/logo", "sway/workspaces"],
  "modules-center": ["clock"],
  "modules-right":  ["cpu", "memory", "pulseaudio", "network", "tray"],

  "custom/logo": {
    "format": "  Flynn OS  ",
    "tooltip": false,
    "on-click": "exec rofi -show drun -theme /root/.config/rofi/tron.rasi"
  },

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a  %d %b  %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "interval": 1,
    "on-click": "exec sh -c 'swaymsg output - dpms toggle'"
  },

  "cpu": {
    "format": "CPU {usage}%",
    "interval": 3,
    "tooltip": false,
    "states": { "warning": 70, "critical": 90 }
  },

  "memory": {
    "format": "MEM {percentage}%",
    "interval": 5,
    "tooltip-format": "{used:0.1f}G of {total:0.1f}G"
  },

  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "MUTE",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%",
    "tooltip": false
  },

  "network": {
    "format-wifi":         "{signalStrength}%",
    "format-ethernet":     "ETH",
    "format-disconnected": "---",
    "tooltip-format": "{ifname}  {ipaddr}",
    "on-click": "nm-connection-editor",
    "interval": 15
  },

  "tray": {
    "spacing": 8,
    "icon-size": 14
  }
}
