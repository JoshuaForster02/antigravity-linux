{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 0,
  "exclusive": true,
  "modules-left": [
    "custom/logo",
    "sway/workspaces",
    "custom/mode"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "idle_inhibitor",
    "cpu",
    "memory",
    "temperature",
    "battery",
    "pulseaudio",
    "bluetooth",
    "network",
    "tray",
    "custom/power"
  ],
  "custom/logo": {
    "format": "ÔùÄ  Flynn OS",
    "tooltip-format": "App Launcher  (Super+D)",
    "on-click": "fuzzel"
  },
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },
  "custom/mode": {
    "exec": "bash -c 'm=$(cat /tmp/flynnos-mode 2>/dev/null||echo study); [ \"$m\" = game ] && echo \"´äø Game\" || echo \"´Ç¡ Study\"'",
    "interval": 2,
    "tooltip-format": "Game / Study mode  (Super+G)",
    "on-click": "/usr/local/bin/game-mode-switch.sh toggle"
  },
  "clock": {
    "format": "{:%a %d %b   %H:%M}",
    "format-alt": "{:%Y-%m-%d   %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "interval": 1
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "´ü«",
      "deactivated": "´ü░"
    },
    "tooltip-format-activated": "Screen stays awake",
    "tooltip-format-deactivated": "Auto-lock active"
  },
  "cpu": {
    "format": "´ïø {usage}%",
    "interval": 3,
    "tooltip-format": "CPU {usage}%",
    "on-click": "foot -e btop",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },
  "memory": {
    "format": "´ö© {percentage}%",
    "interval": 5,
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G",
    "on-click": "foot -e btop"
  },
  "temperature": {
    "critical-threshold": 85,
    "format": "´ïç {temperatureC}┬░",
    "tooltip-format": "Thermal {temperatureC}┬░C",
    "interval": 5
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "´âğ {capacity}%",
    "format-plugged": "´çĞ {capacity}%",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
    "interval": 20
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "´Ü®",
    "format-icons": { "default": ["´ÇĞ", "´Çğ", "´Ç¿"] },
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +3%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -3%"
  },
  "bluetooth": {
    "format": "´èö",
    "format-connected": "´èô {num_connections}",
    "format-disabled": "",
    "format-off": "",
    "tooltip-format": "{device_alias}",
    "on-click": "blueman-manager"
  },
  "network": {
    "format-wifi": "´ç½ {signalStrength}%",
    "format-ethernet": "´ø┐",
    "format-disconnected": "´äğ",
    "tooltip-format": "{ifname}  {ipaddr}/{cidr}",
    "on-click": "/usr/local/bin/flynn-wifi",
    "on-click-right": "nm-connection-editor",
    "interval": 10
  },
  "tray": {
    "spacing": 8,
    "icon-size": 15
  },
  "custom/power": {
    "format": "´Çæ",
    "tooltip-format": "Power  (Super+Escape)",
    "on-click": "/usr/local/bin/flynn-power"
  }
}
