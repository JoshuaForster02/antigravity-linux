#!/bin/bash
# Flynn OS — OTA Update v2 (channels)
# Pulls the Flynn OS overlay live from GitHub and applies it to the running
# system. No ISO rebuild needed.
#
#   Channel config:  /etc/flynnos/update.conf   CHANNEL=stable|dev
#     stable -> branch main        dev -> branch dev
#
# Usage: flynn-update [--auto] [--channel stable|dev] [--full]
#   --auto     non-interactive (used by flynn-update.timer)
#   --full     also run pacman -Syu (package upgrade)

set -u
CY='\e[1;36m' GN='\e[1;32m' YL='\e[0;33m' RD='\e[0;31m' DIM='\e[2;37m' RST='\e[0m'
ok()   { printf "${GN}  ✓  %s${RST}\n" "$*"; }
info() { printf "${CY}  ›  %s${RST}\n" "$*"; }
warn() { printf "${YL}  !  %s${RST}\n" "$*"; }
fail() { printf "${RD}  ✗  %s${RST}\n" "$*"; }

REPO="JoshuaForster02/antigravity-linux"
REPO_URL="https://github.com/$REPO.git"
CACHE="/var/cache/flynnos/repo"
CONF="/etc/flynnos/update.conf"
LOG="/var/log/flynn-update.log"
AUTO=0; FULL=0

mkdir -p /etc/flynnos /var/log "$(dirname "$CACHE")"
[ -f "$CONF" ] || echo "CHANNEL=stable" > "$CONF"
CHANNEL=$(grep -oP 'CHANNEL=\K\w+' "$CONF" 2>/dev/null || echo stable)

while [ $# -gt 0 ]; do
    case "$1" in
        --auto) AUTO=1 ;;
        --full) FULL=1 ;;
        --channel) shift; CHANNEL="${1:-stable}"
                   echo "CHANNEL=$CHANNEL" > "$CONF" ;;
    esac
    shift
done

case "$CHANNEL" in
    dev) BRANCH=dev ;;
    *)   BRANCH=main ;;
esac

log() { echo "$(date '+%F %T') $*" >> "$LOG"; }

echo ""
printf "   ${CY}◎${RST}  Flynn OS OTA   ${DIM}channel: ${CHANNEL} (${BRANCH})${RST}\n"
echo ""

# ── 1. Fetch ──────────────────────────────────────────────────────────────────
info "Fetching ${REPO}@${BRANCH}…"
if [ -d "$CACHE/.git" ]; then
    git -C "$CACHE" fetch origin "$BRANCH" --depth 1 2>/dev/null \
        && git -C "$CACHE" reset --hard "origin/$BRANCH" >/dev/null 2>&1
else
    rm -rf "$CACHE"
    git clone --depth 1 --branch "$BRANCH" "$REPO_URL" "$CACHE" 2>/dev/null
fi
if [ ! -d "$CACHE/archiso/airootfs" ]; then
    fail "Fetch failed — network down or branch '$BRANCH' missing."
    log "fetch failed channel=$CHANNEL"
    exit 1
fi
NEW_REV=$(git -C "$CACHE" rev-parse --short HEAD)
CUR_REV=$(cat /etc/flynnos/.ota-rev 2>/dev/null || echo none)
if [ "$NEW_REV" = "$CUR_REV" ]; then
    ok "Already up to date ($NEW_REV)"
    [ "$FULL" = 1 ] || exit 0
else
    info "Update: $CUR_REV → $NEW_REV"
fi

# ── 2. Apply overlay (scripts, configs, themes) ───────────────────────────────
SRC="$CACHE/archiso/airootfs"
info "Applying overlay…"
rsync -a "$SRC/usr/local/bin/"   /usr/local/bin/   2>/dev/null
rsync -a "$SRC/usr/local/share/" /usr/local/share/ 2>/dev/null
rsync -a "$SRC/usr/share/themes/" /usr/share/themes/ 2>/dev/null
rsync -a "$SRC/usr/share/plymouth/" /usr/share/plymouth/ 2>/dev/null
rsync -a "$SRC/opt/flynn/"       /opt/flynn/       2>/dev/null
rsync -a "$SRC/root/.config/"    /root/.config/    2>/dev/null
rsync -a "$SRC/etc/keyd/"        /etc/keyd/        2>/dev/null
find /usr/local/bin -type f -exec chmod +x {} \; 2>/dev/null
find /opt/flynn -name "*.py" -exec chmod +x {} \; 2>/dev/null
echo "$NEW_REV" > /etc/flynnos/.ota-rev
log "applied $NEW_REV channel=$CHANNEL"
ok "Overlay applied ($NEW_REV)"

# ── 3. Reload live components ─────────────────────────────────────────────────
if [ -n "${WAYLAND_DISPLAY:-}" ] || pgrep -x sway >/dev/null; then
    swaymsg reload >/dev/null 2>&1 && ok "Desktop reloaded" || true
fi
systemctl restart keyd 2>/dev/null || true

# ── 4. Optional full package upgrade ──────────────────────────────────────────
if [ "$FULL" = 1 ]; then
    info "Package upgrade (pacman -Syu)…"
    if [ "$AUTO" = 1 ]; then
        pacman -Syu --noconfirm >/dev/null 2>&1 && ok "Packages updated" || warn "pacman failed — run manually"
    else
        pacman -Syu
    fi
fi

echo ""
ok "Flynn OS is current.  ${DIM}channel: $CHANNEL · rev: $NEW_REV${RST}"
info "Switch channel:  flynn-update --channel dev   (back: --channel stable)"
echo ""
