#!/usr/bin/env python3
"""
Flynn OS — First Boot Setup Wizard
Runs once on first login: keyboard layout, network, quick tour.
Re-run anytime:  flynn-first-boot --force
"""
import gi, os, subprocess, threading
gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, GLib

DONE_FLAG = "/etc/flynnos/.first-boot-done"

CSS = b"""
window    { background: rgba(12, 20, 34, 0.98); border-radius: 16px; }
.title    { color:#e6f4fb; font-family:"Noto Sans"; font-size:24px; font-weight:bold; }
.subtitle { color:#5ad7ff; font-family:"Noto Sans"; font-size:12px; }
.step     { color:#8fe5ff; font-family:"Noto Sans"; font-size:14px; font-weight:bold; }
.label    { color:#c8dfec; font-family:"Noto Sans"; font-size:13px; }
.small    { color:#56788c; font-family:"Noto Sans"; font-size:10px; }
button    { background:rgba(122,216,248,0.10); color:#cfe9f5;
            border:1px solid rgba(122,216,248,0.22);
            border-radius:12px; font-family:"Noto Sans"; font-size:13px; padding:10px 22px; }
button:hover   { background:rgba(122,216,248,0.18); color:#ffffff; }
button.primary { background:#1d3850; border-color:#5ad7ff; color:#8fe5ff; font-weight:bold; }
button.primary:hover { background:#24496a; color:#ffffff; }
button.skip    { color:#56788c; border-color:rgba(122,216,248,0.10); }
button.selected { background:#5ad7ff; color:#0c1422; border-color:#5ad7ff; font-weight:bold; }
"""

STEPS = ["Welcome", "Keyboard", "Network", "Ready"]


class SetupWizard(Gtk.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app, title="Flynn OS Setup")
        self.set_default_size(680, 480)
        self.set_resizable(False)
        self._step = 0

        p = Gtk.CssProvider(); p.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_display(
            self.get_display(), p, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self._root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self._root.set_margin_top(32); self._root.set_margin_bottom(24)
        self._root.set_margin_start(48); self._root.set_margin_end(48)
        self.set_child(self._root)
        self._show_step()

    def _clear(self):
        while (ch := self._root.get_first_child()) is not None:
            self._root.remove(ch)

    def _show_step(self):
        self._clear()
        [self._step_welcome, self._step_keyboard,
         self._step_network, self._step_done][self._step]()

    def _header(self, title, subtitle=""):
        t = Gtk.Label(label=title); t.add_css_class("title"); t.set_halign(Gtk.Align.START)
        self._root.append(t)
        if subtitle:
            s = Gtk.Label(label=subtitle); s.add_css_class("subtitle"); s.set_halign(Gtk.Align.START)
            self._root.append(s)
        ind = Gtk.Label(label="  ·  ".join(
            f"●  {s}" if i == self._step else f"○  {s}" for i, s in enumerate(STEPS)))
        ind.add_css_class("small"); ind.set_halign(Gtk.Align.START)
        ind.set_margin_top(8); ind.set_margin_bottom(20)
        self._root.append(ind)

    def _nav(self, next_label="Next  →", skip=False, on_next=None):
        bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        bar.set_margin_top(24); bar.set_valign(Gtk.Align.END); bar.set_vexpand(True)
        bar.set_halign(Gtk.Align.END)
        if skip:
            sb = Gtk.Button(label="Skip"); sb.add_css_class("skip")
            sb.connect("clicked", lambda _: self._next())
            bar.append(sb)
        nb = Gtk.Button(label=next_label); nb.add_css_class("primary")
        nb.connect("clicked", lambda _: (on_next or self._next)())
        bar.append(nb)
        self._root.append(bar)
        return nb

    def _next(self):
        self._step += 1
        self._show_step()

    def _lines(self, lines):
        for line in lines:
            l = Gtk.Label(label=line); l.add_css_class("label")
            l.set_halign(Gtk.Align.START)
            self._root.append(l)

    # ── Steps ────────────────────────────────────────────────────────────────
    def _step_welcome(self):
        self._header("Welcome to Flynn OS", "Arch Linux  ·  linux-zen  ·  The Grid")
        self._lines([
            "Let's set up the essentials — takes 30 seconds.",
            "",
            "What you get:",
            "   ·  Clean ENCOM desktop (Sway / Wayland)",
            "   ·  Dock with running apps  ·  Wi-Fi picker  ·  Window switcher",
            "   ·  Notion, Anki, Amboss  ·  Steam via flynn-setup",
            "",
            "You can re-run this wizard anytime:  flynn-first-boot --force",
        ])
        self._nav("Start  →")

    def _step_keyboard(self):
        self._header("Keyboard Layout", "Important for your password!")
        self._lines([
            "Choose your physical keyboard layout.",
            "On a German MacBook, choose German — otherwise Y and Z are swapped.",
            "",
        ])
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        de_btn = Gtk.Button(label="  German (QWERTZ)")
        us_btn = Gtk.Button(label="  English (US)")
        def choose(layout, btn, other):
            subprocess.run(["/usr/local/bin/flynn-keyboard", layout],
                           capture_output=True)
            btn.add_css_class("selected")
            other.remove_css_class("selected")
        de_btn.connect("clicked", lambda _: choose("de", de_btn, us_btn))
        us_btn.connect("clicked", lambda _: choose("us", us_btn, de_btn))
        us_btn.add_css_class("selected")   # current default
        box.append(de_btn); box.append(us_btn)
        self._root.append(box)
        hint = Gtk.Label(label="\nSwitch later anytime:  Super+F2  or  Settings (Super+,)")
        hint.add_css_class("small"); hint.set_halign(Gtk.Align.START)
        self._root.append(hint)
        self._nav()

    def _step_network(self):
        self._header("Network", "Wi-Fi or Ethernet")
        status_lbl = Gtk.Label(label="Checking…"); status_lbl.add_css_class("step")
        status_lbl.set_halign(Gtk.Align.START); status_lbl.set_margin_bottom(12)
        self._root.append(status_lbl)

        def check():
            try:
                r = subprocess.run(["ping", "-c1", "-W2", "8.8.8.8"],
                                   capture_output=True)
                ok = r.returncode == 0
            except Exception:
                ok = False
            GLib.idle_add(status_lbl.set_label,
                          "✓  Online" if ok else "✗  Offline — pick a Wi-Fi below")

        threading.Thread(target=check, daemon=True).start()

        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        wifi_btn = Gtk.Button(label="  Choose Wi-Fi"); wifi_btn.add_css_class("primary")
        wifi_btn.connect("clicked", lambda _: subprocess.Popen(["/usr/local/bin/flynn-wifi"]))
        edit_btn = Gtk.Button(label="Connection Editor")
        edit_btn.connect("clicked", lambda _: subprocess.Popen(["nm-connection-editor"]))
        box.append(wifi_btn); box.append(edit_btn)
        self._root.append(box)
        self._nav(skip=True)

    def _step_done(self):
        self._header("You're all set", "The Grid is online")
        self._lines([
            "The essentials:",
            "",
            "   Super+Return   Terminal            Super+D      App launcher",
            "   Super+Tab      Window switcher     Super+Q      Close window",
            "   Super+W        Wi-Fi               Super+,      Settings",
            "   Super+F        Fullscreen          Super+?      All shortcuts",
            "   Super+Escape   Power menu",
            "",
            "Install Steam / Anki / GPU extras:  run  flynn-setup  in the terminal.",
        ])
        os.makedirs("/etc/flynnos", exist_ok=True)
        open(DONE_FLAG, "w").close()
        self._nav("Launch Desktop  →", on_next=self.close)


class SetupApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="org.flynnos.setup")
    def do_activate(self):
        SetupWizard(self).present()


if __name__ == "__main__":
    import sys
    if os.path.exists(DONE_FLAG) and "--force" not in sys.argv:
        print("First boot already completed. Run with --force to re-run.")
        sys.exit(0)
    SetupApp().run([a for a in sys.argv if a != "--force"])
