#!/usr/bin/env python3
"""Flynn OS screen chrome — TRON Legacy corner brackets + scan line."""
import gi, math
gi.require_version("Gtk", "4.0")
gi.require_version("GtkLayerShell", "0.1")
from gi.repository import Gtk, GLib, GtkLayerShell
import cairo

CYAN = (0.49, 0.91, 1.0)
DIM  = (0.23, 0.55, 0.65)
SCAN_Y = 0
FRAME = 0

class Chrome(Gtk.Application):
    def do_activate(self):
        win = Gtk.ApplicationWindow(application=self)
        win.set_decorated(False)
        GtkLayerShell.init_for_window(win)
        GtkLayerShell.set_layer(win, GtkLayerShell.Layer.BACKGROUND)
        for e in (GtkLayerShell.Edge.TOP, GtkLayerShell.Edge.BOTTOM,
                  GtkLayerShell.Edge.LEFT, GtkLayerShell.Edge.RIGHT):
            GtkLayerShell.set_anchor(win, e, True)
        GtkLayerShell.set_exclusive_zone(win, -1)
        GtkLayerShell.set_keyboard_mode(win, GtkLayerShell.KeyboardMode.NONE)
        da = Gtk.DrawingArea()
        da.set_draw_func(self._draw, None)
        win.set_child(da)
        win.present()
        GLib.timeout_add(33, self._tick, da)

    def _tick(self, da):
        global SCAN_Y, FRAME
        SCAN_Y = (SCAN_Y + 2.5) % 4000
        FRAME += 1
        da.queue_draw()
        return True

    def _draw(self, _da, cr, w, h, _u):
        cr.set_source_rgb(0, 0, 0)
        cr.paint()
        step = 64
        cr.set_line_width(1.0)
        for x in range(0, int(w)+step, step):
            cr.set_source_rgba(*DIM, 0.14)
            cr.move_to(x, 0); cr.line_to(x, h); cr.stroke()
        for y in range(0, int(h)+step, step):
            cr.set_source_rgba(*DIM, 0.14)
            cr.move_to(0, y); cr.line_to(w, y); cr.stroke()
        L = 52
        cr.set_source_rgba(*CYAN, 0.6)
        cr.set_line_width(1.5)
        corners = [(14,14,14+L,14,14,14+L),(w-14,14,w-14-L,14,w-14,14+L),
                   (14,h-14,14+L,h-14,14,h-14-L),(w-14,h-14,w-14-L,h-14,w-14,h-14-L)]
        for x1,y1,x2,y2,x3,y3 in corners:
            cr.move_to(x1,y1); cr.line_to(x2,y2)
            cr.move_to(x1,y1); cr.line_to(x3,y3); cr.stroke()
        sy = SCAN_Y % max(int(h), 1)
        g = cairo.LinearGradient(0, sy-50, 0, sy+50)
        g.add_color_stop_rgba(0, *CYAN, 0)
        g.add_color_stop_rgba(0.5, *CYAN, 0.09)
        g.add_color_stop_rgba(1, *CYAN, 0)
        cr.set_source(g); cr.rectangle(0, sy-50, w, 100); cr.fill()
        pulse = 0.3 + 0.25*math.sin(FRAME*0.04)
        cr.set_source_rgba(*CYAN, pulse)
        cr.rectangle(0, 0, w, 1); cr.fill()

if __name__ == "__main__":
    Chrome(application_id="org.flynnos.chrome").run([])
