#!/usr/bin/env python3
"""
Flynn OS — Live Background Daemon  (ENCOM clean)
Animated grid rendered via Cairo + GTK4 layer shell at the BACKGROUND layer.

Performance: the static layer (gradient, grid, dots, corners) is rendered ONCE
into a cached surface and blitted per frame — only packets, pulses and the
breathing glow are dynamic. ~10x cheaper than a full redraw, fine for
software rendering (UTM/QEMU pixman).

Config:  /etc/flynnos/bg.conf      MODE=live|off   FPS=20
Control: flynn-bg [on|off|toggle]
"""

import gi, math, random, os
gi.require_version('Gtk', '4.0')
from gi.repository import Gtk, Gdk, GLib

try:
    gi.require_version('GtkLayerShell', '0.1')
    from gi.repository import GtkLayerShell
    HAS_LAYER = True
except Exception:
    HAS_LAYER = False

import cairo

# ── Config ─────────────────────────────────────────────────────────────────────
CONF = "/etc/flynnos/bg.conf"
def read_conf():
    cfg = {"MODE": "live", "FPS": "20"}
    try:
        with open(CONF) as f:
            for line in f:
                if "=" in line:
                    k, v = line.strip().split("=", 1)
                    cfg[k.strip()] = v.strip()
    except Exception:
        pass
    return cfg

CFG = read_conf()
if CFG.get("MODE") == "off":
    raise SystemExit(0)

FPS      = max(5, min(30, int(CFG.get("FPS", "20"))))
INTERVAL = 1000 // FPS
GRID     = 72

# ── Palette (Ice Grid design system) ──────────────────────────────────────────
BG_TOP    = (0.027, 0.031, 0.047)   # #07080c
BG_MID    = (0.059, 0.067, 0.094)   # #0f1118
LINE_COL  = (0.624, 0.863, 0.961)   # #9fdcf5
ACCENT    = (0.624, 0.863, 0.961)   # #9fdcf5
NODE_COL  = (0.420, 0.522, 0.604)   # #6b859a

# ── Data Packet ───────────────────────────────────────────────────────────────
class Packet:
    """A small light streak traveling along grid lines."""
    def __init__(self, w, h):
        self.reset(w, h)

    def reset(self, w, h):
        if random.random() < 0.5:           # horizontal
            self.x  = -60.0
            self.y  = random.randint(1, max(1, h // GRID - 1)) * GRID
            self.dx = random.uniform(1.8, 4.2)
            self.dy = 0.0
            self.w, self.h_px = random.randint(22, 56), 2
        else:                               # vertical
            self.x  = random.randint(1, max(1, w // GRID - 1)) * GRID
            self.y  = -60.0
            self.dx = 0.0
            self.dy = random.uniform(1.5, 3.5)
            self.w, self.h_px = 2, random.randint(22, 56)
        self.alpha = random.uniform(0.35, 0.75)
        self._W, self._H = w, h

    def step(self):
        self.x += self.dx
        self.y += self.dy
        if self.x > self._W + 80 or self.y > self._H + 80:
            self.reset(self._W, self._H)

    def draw(self, ctx):
        ctx.set_source_rgba(*ACCENT, self.alpha)
        ctx.rectangle(self.x, self.y, self.w, self.h_px)
        ctx.fill()
        # soft trailing glow
        ctx.set_source_rgba(*ACCENT, self.alpha * 0.20)
        if self.dx > 0:
            ctx.rectangle(self.x - 14, self.y, 14, self.h_px)
        else:
            ctx.rectangle(self.x, self.y - 14, self.w, 14)
        ctx.fill()

# ── Pulse ring ────────────────────────────────────────────────────────────────
class Pulse:
    def __init__(self, x, y):
        self.x, self.y = x, y
        self.r     = 0.0
        self.alpha = 0.55

    @property
    def done(self):
        return self.alpha <= 0.02

    def step(self):
        self.r     += 1.2
        self.alpha *= 0.90

    def draw(self, ctx):
        ctx.set_source_rgba(*ACCENT, self.alpha * 0.6)
        ctx.arc(self.x, self.y, self.r, 0, 2 * math.pi)
        ctx.stroke()

# ── Background window ─────────────────────────────────────────────────────────
class FlynnBackground(Gtk.ApplicationWindow):
    def __init__(self, app):
        super().__init__(application=app)
        self.set_decorated(False)
        self.set_default_size(1920, 1080)

        if HAS_LAYER:
            GtkLayerShell.init_for_window(self)
            GtkLayerShell.set_layer(self, GtkLayerShell.Layer.BACKGROUND)
            for edge in (GtkLayerShell.Edge.TOP, GtkLayerShell.Edge.BOTTOM,
                         GtkLayerShell.Edge.LEFT, GtkLayerShell.Edge.RIGHT):
                GtkLayerShell.set_anchor(self, edge, True)
            GtkLayerShell.set_exclusive_zone(self, -1)

        self._t          = 0
        self._packets    = []
        self._pulses     = []
        self._next_pulse = random.randint(40, 110)
        self._static     = None          # cached static layer
        self._size       = (0, 0)

        area = Gtk.DrawingArea()
        area.set_draw_func(self._draw)
        self.set_child(area)
        self._area = area

        GLib.timeout_add(INTERVAL, self._tick)

    # ── Static layer: rendered once per size ──────────────────────────────────
    def _build_static(self, w, h):
        surf = cairo.ImageSurface(cairo.FORMAT_RGB24, w, h)
        ctx  = cairo.Context(surf)

        # Vertical gradient — deep navy, brighter towards center
        grad = cairo.LinearGradient(0, 0, 0, h)
        grad.add_color_stop_rgb(0.0, *BG_TOP)
        grad.add_color_stop_rgb(0.5, *BG_MID)
        grad.add_color_stop_rgb(1.0, *BG_TOP)
        ctx.set_source(grad)
        ctx.paint()

        # Grid
        ctx.set_line_width(1)
        for gx in range(0, w + GRID, GRID):
            accent = (gx % (GRID * 4) == 0)
            ctx.set_source_rgba(*LINE_COL, 0.16 if accent else 0.06)
            ctx.move_to(gx, 0); ctx.line_to(gx, h); ctx.stroke()
        for gy in range(0, h + GRID, GRID):
            accent = (gy % (GRID * 4) == 0)
            ctx.set_source_rgba(*LINE_COL, 0.16 if accent else 0.06)
            ctx.move_to(0, gy); ctx.line_to(w, gy); ctx.stroke()

        # Sparse node dots
        rng = random.Random(2049)
        ctx.set_source_rgba(*NODE_COL, 0.30)
        for gx in range(GRID, w, GRID):
            for gy in range(GRID, h, GRID):
                if rng.random() < 0.10:
                    ctx.arc(gx, gy, 1.6, 0, 2 * math.pi)
                    ctx.fill()

        # Corner chrome
        ctx.set_line_width(1.5)
        ctx.set_source_rgba(*ACCENT, 0.38)
        pad, size = 24, 30
        for cx, cy, sx, sy in [(pad, pad, 1, 1), (w - pad, pad, -1, 1),
                               (pad, h - pad, 1, -1), (w - pad, h - pad, -1, -1)]:
            ctx.move_to(cx, cy + sy * size)
            ctx.line_to(cx, cy)
            ctx.line_to(cx + sx * size, cy)
            ctx.stroke()

        return surf

    def _tick(self):
        self._t += 1
        for p in self._packets:
            p.step()
        for p in self._pulses:
            p.step()
        self._pulses = [p for p in self._pulses if not p.done]

        self._next_pulse -= 1
        if self._next_pulse <= 0 and self._size[0] > 0:
            w, h = self._size
            gx = random.randint(1, max(1, w // GRID - 1)) * GRID
            gy = random.randint(1, max(1, h // GRID - 1)) * GRID
            self._pulses.append(Pulse(gx, gy))
            self._next_pulse = random.randint(40, 120)

        self._area.queue_draw()
        return True

    def _draw(self, area, ctx, w, h):
        # (Re)build cache on first draw or resize
        if self._static is None or self._size != (w, h):
            self._static = self._build_static(w, h)
            self._size   = (w, h)
            self._packets = [Packet(w, h) for _ in range(10)]

        # Blit static layer
        ctx.set_source_surface(self._static, 0, 0)
        ctx.paint()

        # Breathing top edge glow
        breath = 0.5 + 0.5 * math.sin(self._t * 0.015)
        ctx.set_source_rgba(*ACCENT, 0.05 + 0.05 * breath)
        ctx.rectangle(0, 0, w, 2)
        ctx.fill()

        # Dynamic elements
        for p in self._packets:
            p.draw(ctx)
        ctx.set_line_width(1.2)
        for p in self._pulses:
            p.draw(ctx)


class App(Gtk.Application):
    def __init__(self):
        super().__init__(application_id='os.flynnos.background')
        self.connect('activate', lambda app: FlynnBackground(app).present())

App().run([])
