#!/bin/bash
# Flynn OS — One-shot welcome OSD after Sway starts
FLAG=/run/flynn-welcome.done
[ -f "$FLAG" ] && exit 0
touch "$FLAG"
sleep 1.2
notify-send -a "Flynn OS" -u low -t 8000 -i dialog-information \
    "Greetings, program." \
    "Super+D Launcher  ·  Super+Tab Windows  ·  Super+I Wi-Fi\nSuper+, Settings  ·  Super+? All shortcuts" 2>/dev/null || true
