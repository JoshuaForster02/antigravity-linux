    color: #004466;
    font-family: "JetBrains Mono";
    font-size: 10px;
    letter-spacing: 2px;
}
.stat-label {
    color: #004466;
    font-family: "JetBrains Mono";
    font-size: 11px;
}
.stat-value {
    color: #00e5ff;
    font-family: "JetBrains Mono";
    font-size: 11px;
    font-weight: bold;
}
.section-header {
    color: #00aacc;
    font-family: "JetBrains Mono";
