#!/usr/bin/env python3
"""
Flynn OS Dashboard — TRON Control Panel
GTK4 floating window: System stats, App launchers, Pi status, Game Mode
"""
import gi, subprocess, threading, time, os, json
gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, GLib, Pango

