#!/bin/bash
# Flynn OS — Setup (Steam · Anki · GPU · Proton-GE)
# Works on the live ISO and on an installed system.

CY='\e[1;36m' GN='\e[1;32m' YL='\e[0;33m' RD='\e[0;31m' DIM='\e[2;37m' WHT='\e[1;37m' RST='\e[0m'
ok()   { printf "${GN}  ✓  %s${RST}\n" "$*"; }
info() { printf "${CY}  ›  %s${RST}\n" "$*"; }
warn() { printf "${YL}  !  %s${RST}\n" "$*"; }
fail() { printf "${RD}  ✗  %s${RST}\n" "$*"; }
ask()  { printf "${WHT}  ?  %s${RST} " "$*"; }

echo ""
printf "   ${CY}◎${RST}  ${WHT}Flynn OS Setup${RST}   ${DIM}Steam · Anki · GPU${RST}\n"
echo ""

# ── 0. Live-ISO warning ───────────────────────────────────────────────────────
if [ -d /run/archiso ]; then
    warn "You are on the LIVE ISO — installs go to RAM and vanish on reboot."
    warn "For a permanent system run:  flynn-install   first."
    ask "Continue anyway? [y/N]"; read -r R
    [[ "${R:-n}" =~ ^[Yy] ]] || exit 0
    echo ""
fi

# ── 1. Network ────────────────────────────────────────────────────────────────
info "Step 1/4 — Network"
if ping -c1 -W3 archlinux.org >/dev/null 2>&1; then
    ok "Online"
else
    fail "No internet connection."
    info "Wi-Fi:  flynn-wifi   ·   Ethernet: should connect automatically"
    info "Check:  nmcli device status"
    exit 1
fi
echo ""

# ── 2. GPU ────────────────────────────────────────────────────────────────────
info "Step 2/4 — GPU"
GPU=$(lspci 2>/dev/null | grep -i "VGA\|3D" | head -1 | cut -d: -f3)
info "Detected:${GPU:- unknown}"
if echo "$GPU" | grep -qi "AMD\|ATI\|Radeon"; then
    usermod -a -G video,render root 2>/dev/null
    cat > /etc/profile.d/flynn-gpu.sh << 'GPUENV'
export AMD_VULKAN_ICD=RADV
export RADV_PERFTEST=aco
export DXVK_ASYNC=1
GPUENV
    ok "AMD: RADV + DXVK flags set"
elif echo "$GPU" | grep -qi "NVIDIA"; then
    warn "NVIDIA detected — install drivers manually: pacman -S nvidia-dkms"
else
    info "Using default Mesa drivers"
fi
echo ""

# ── 3. Packages (Steam + Anki + gaming libs) ─────────────────────────────────
info "Step 3/4 — Packages"
PKGS=(steam lib32-mesa lib32-vulkan-radeon lib32-gamemode lib32-mangohud anki)
MISSING=()
for p in "${PKGS[@]}"; do pacman -Q "$p" &>/dev/null || MISSING+=("$p"); done

if [ ${#MISSING[@]} -eq 0 ]; then
    ok "Everything already installed"
else
    info "To install: ${MISSING[*]}"
    ask "Install now? [Y/n]"; read -r R
    if [[ "${R:-y}" =~ ^[Yy] ]]; then
        info "Syncing package databases…"
        if ! pacman -Sy; then
            fail "Database sync failed — check your network and try again."
            exit 1
        fi
        if pacman -S --noconfirm --needed "${MISSING[@]}"; then
            ok "Installed: ${MISSING[*]}"
        else
            fail "Some packages failed — scroll up for pacman's error."
            warn "You can retry individually, e.g.:  pacman -S steam"
        fi
    fi
fi
echo ""

# ── 4. Proton-GE (optional) ───────────────────────────────────────────────────
info "Step 4/5 — Proton-GE (better game compatibility, optional)"
ask "Download latest Proton-GE? [y/N]"; read -r R
if [[ "${R:-n}" =~ ^[Yy] ]]; then
    /usr/local/bin/proton-ge-install || warn "Proton-GE install failed — retry later with: proton-ge-install"
fi

# ── 5. AUR extras (yay → SwayFX rounded corners/blur, Sunshine…) ─────────
info "Step 5/5 — AUR extras (optional)"
if ! command -v yay >/dev/null; then
    ask "Install yay (AUR helper — unlocks SwayFX, Sunshine, Discord…)? [y/N]"; read -r R
    if [[ "${R:-n}" =~ ^[Yy] ]]; then
        # makepkg refuses root — dedicated build user does the compiling
        id builder >/dev/null 2>&1 || useradd -r -m -s /bin/bash builder
        echo 'builder ALL=(ALL) NOPASSWD: /usr/bin/pacman' > /etc/sudoers.d/builder
        chmod 440 /etc/sudoers.d/builder
        pacman -S --noconfirm --needed git base-devel 2>/dev/null || true
        runuser -u builder -- bash -c '
            set -e
            cd /tmp && rm -rf yay-bin
            git clone --depth 1 https://aur.archlinux.org/yay-bin.git
            cd yay-bin && makepkg -si --noconfirm
        ' && ok "yay installed" || warn "yay build failed — see output above"
    fi
fi
if command -v yay >/dev/null; then
    ask "Install SwayFX (real rounded corners + blur)? [y/N]"; read -r R
    if [[ "${R:-n}" =~ ^[Yy] ]]; then
        runuser -u builder -- yay -S --noconfirm swayfx \
            && ok "SwayFX installed — it replaces sway at next login" \
            || warn "SwayFX build failed"
    fi
    info "More AUR ideas:  runuser -u builder -- yay -S sunshine discord spotify"
fi
echo ""

# Default Flynn config (only if absent — never overwrite)
if [ ! -f /etc/flynn/config.json ]; then
    mkdir -p /etc/flynn
    printf '{\n  "daemon_port": 7777,\n  "notion_token": "",\n  "pi_host": "",\n  "pc_mac": ""\n}\n' > /etc/flynn/config.json
fi

echo ""
ok "Setup complete."
info "Steam:  Super+G toggles GameMode  ·  dock has a Steam button"
info "Anki:   dock button or 'anki' in terminal"
info "Extras: swayfx (rounded corners/blur) via AUR once installed to disk"
echo ""
printf "   ${DIM}END OF LINE_${RST}\n\n"
