#!/usr/bin/env python3
"""Draw a TRON grid on the X11 root window via xsetroot + xterm fallback."""
import subprocess, sys, os

# Try to use xdotool/xsetroot for a quick solid color first
subprocess.run(["xsetroot", "-solid", "#000810"], capture_output=True)

