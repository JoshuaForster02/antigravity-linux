#!/bin/bash
# Flynn OS — Night light toggle (wlsunset, warm color at night)
if pgrep -x wlsunset >/dev/null; then
    pkill -x wlsunset
    /usr/local/bin/flynn-notify display "Night light: off"
else
    # Berlin-ish coordinates; -t night temp, -T day temp
    nohup wlsunset -l 52.5 -L 13.4 -t 3700 -T 6500 >/dev/null 2>&1 &
    /usr/local/bin/flynn-notify display "Night light: on"
fi
