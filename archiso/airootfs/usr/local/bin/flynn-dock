#!/usr/bin/env python3
"""
Flynn OS — ANTIGRAVITY Dock
macOS-style floating dock: centered bottom, frosted glass, ENCOM OS aesthetic.

Layout:  ╭─────────────────────────────────────────╮
         │  ▶  ⬡  ≡  ◈  ⊞  ◉  🎵  ⚙  ⏻          │
         │  ·                    ·                  │  ← running indicators
         ╰─────────────────────────────────────────╯
"""

import gi, subprocess, os, time
gi.require_version('Gtk', '4.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, Gdk, GLib
try:
    from gi.repository import GtkLayerShell
    HAS_LAYER = True
except Exception:
    HAS_LAYER = False

CSS = b"""
/* ── Dock window ──────────────────────────────────────────────────────────── */
window {
    background: transparent;
}

/* ── Dock container ───────────────────────────────────────────────────────── */
.dock-box {
    background:    rgba(0, 8, 18, 0.88);
    border:        1px solid rgba(0, 229, 255, 0.28);
    border-radius: 18px;
    padding:       10px 18px 8px 18px;
}

/* ── App button ───────────────────────────────────────────────────────────── */
.app-btn {
    background:    transparent;
    border:        none;
    border-radius: 12px;
    padding:       6px 10px 4px 10px;
    min-width:     52px;
    color:         rgba(0, 200, 230, 0.75);
    transition:    all 0.15s ease;
}

.app-btn:hover {
    background: rgba(0, 229, 255, 0.10);
    color:      #00e5ff;
}

.app-btn:active {
    background: rgba(0, 229, 255, 0.20);
}

/* ── App icon label ───────────────────────────────────────────────────────── */
.app-icon {
    font-size:   20px;
    color:       inherit;
}

/* ── App name label ───────────────────────────────────────────────────────── */
.app-name {
    font-family: "JetBrains Mono", monospace;
    font-size:   8px;
    color:       rgba(0, 180, 210, 0.55);
    letter-spacing: 0.5px;
}

/* ── Running dot ──────────────────────────────────────────────────────────── */
.running-dot {
    color:      rgba(0, 229, 255, 0.8);
    font-size:  6px;
    min-height: 8px;
}

/* ── Separator ────────────────────────────────────────────────────────────── */
.dock-sep {
    background:  rgba(0, 229, 255, 0.15);
    min-width:   1px;
    margin:      4px 6px;
}

/* ── Power button ─────────────────────────────────────────────────────────── */
.power-btn {
    background:    transparent;
    border:        none;
    border-radius: 12px;
    padding:       6px 10px 4px 10px;
    min-width:     44px;
    color:         rgba(255, 80, 60, 0.55);
    transition:    all 0.15s ease;
}
.power-btn:hover {
    background: rgba(255, 50, 30, 0.12);
    color:      #ff4030;
}
"""

# ── App definitions ───────────────────────────────────────────────────────────
APPS = [
    ("▶",  "TERM",    "foot -e /usr/local/bin/flynn-ui"),
    ("⬡",  "LAUNCH",  "fuzzel"),
    ("≡",  "NOTION",  "/usr/local/bin/flynn-browser https://notion.so --title Notion"),
    ("◈",  "ANKI",    "/usr/local/bin/flynn-browser http://localhost:8765 --title Anki"),
    ("⊞",  "FILES",   "thunar"),
    ("◉",  "STEAM",   "bash -c 'command -v steam >/dev/null && steam -bigpicture || foot -e bash -c "Run flynn-setup for Steam"; read'"),
    ("⊛",  "NET",     "nm-connection-editor"),
]

class DockApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id='os.flynnos.dock')
        self.connect('activate', self._activate)

    def _activate(self, app):
        win = Gtk.ApplicationWindow(application=app)
        win.set_decorated(False)
        win.set_resizable(False)
        win.set_default_size(1, 1)

        if HAS_LAYER:
            GtkLayerShell.init_for_window(win)
            GtkLayerShell.set_layer(win, GtkLayerShell.Layer.TOP)
            GtkLayerShell.set_anchor(win, GtkLayerShell.Edge.BOTTOM, True)
            GtkLayerShell.set_margin(win, GtkLayerShell.Edge.BOTTOM, 14)
            GtkLayerShell.set_exclusive_zone(win, 78)

        # Apply CSS
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        # Outer transparent container (lets dock float centered)
        outer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        outer.set_halign(Gtk.Align.CENTER)

        dock = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
        dock.add_css_class('dock-box')

        for icon, name, cmd in APPS:
            btn = self._make_app_btn(icon, name, cmd)
            dock.append(btn)

        # Separator before power
        sep = Gtk.Separator(orientation=Gtk.Orientation.VERTICAL)
        sep.add_css_class('dock-sep')
        dock.append(sep)

        # Power button
        power = Gtk.Button()
        power.add_css_class('power-btn')
        pbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        picon = Gtk.Label(label='⏻')
        picon.add_css_class('app-icon')
        pname = Gtk.Label(label='EXIT')
        pname.add_css_class('app-name')
        pbox.append(picon)
        pbox.append(pname)
        power.set_child(pbox)
        power.connect('clicked', lambda _: subprocess.Popen(['swaymsg', 'exit']))
        dock.append(power)

        outer.append(dock)
        win.set_child(outer)
        win.present()

    def _make_app_btn(self, icon, name, cmd):
        btn = Gtk.Button()
        btn.add_css_class('app-btn')

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)

        icon_lbl = Gtk.Label(label=icon)
        icon_lbl.add_css_class('app-icon')

        name_lbl = Gtk.Label(label=name)
        name_lbl.add_css_class('app-name')

        dot = Gtk.Label(label='')   # updated to · when running
        dot.add_css_class('running-dot')
        dot.set_name(f'dot-{name}')

        vbox.append(icon_lbl)
        vbox.append(name_lbl)
        vbox.append(dot)

        btn.set_child(vbox)
        btn.connect('clicked', lambda _, c=cmd: subprocess.Popen(c, shell=True))
        return btn

DockApp().run([])
