#!/usr/bin/env python3
"""Flynn OS — Wallpaper v3  (modern / clean)
Deep navy gradient, soft aurora glows, a whisper of grid fading in from the
bottom. No clutter, no brackets, no neon spam — Antigravity-app aesthetic.
"""
import subprocess, sys, os, math

OUT = "/root/.config/sway/tron-bg.png"
os.makedirs(os.path.dirname(OUT), exist_ok=True)

try:
    from PIL import Image, ImageDraw, ImageFilter
except ImportError:
    print("[wallpaper] PIL not available — using solid color fallback")
    subprocess.Popen(["swaymsg", "output * bg #0c1422 solid_color"],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    sys.exit(0)

W, H = 1920, 1080

# ── 1. Base: smooth vertical gradient (deep navy) ─────────────────────────────
TOP    = (5, 9, 17)      # #050911
MID    = (12, 22, 38)    # #0c1626
BOTTOM = (8, 15, 28)     # #080f1c

img = Image.new("RGB", (W, H))
d   = ImageDraw.Draw(img)
for y in range(H):
    t = y / H
    if t < 0.55:
        f = t / 0.55
        c = tuple(int(TOP[i] + (MID[i] - TOP[i]) * f) for i in range(3))
    else:
        f = (t - 0.55) / 0.45
        c = tuple(int(MID[i] + (BOTTOM[i] - MID[i]) * f) for i in range(3))
    d.line([(0, y), (W, y)], fill=c)

# ── 2. Aurora glows: blurred color washes (modern macOS-wallpaper feel) ──────
glow = Image.new("RGB", (W, H), (0, 0, 0))
g    = ImageDraw.Draw(glow)

# Big soft cyan glow low-center
g.ellipse([W*0.18, H*0.62, W*0.82, H*1.35], fill=(14, 50, 72))
# Teal accent upper-right
g.ellipse([W*0.62, -H*0.25, W*1.25, H*0.30], fill=(8, 30, 46))
# Faint indigo left
g.ellipse([-W*0.20, H*0.10, W*0.28, H*0.70], fill=(16, 22, 52))

glow = glow.filter(ImageFilter.GaussianBlur(180))
# Additive blend keeps blacks deep while glows lift gently
from PIL import ImageChops
img = ImageChops.add(img, glow)

# ── 3. Whisper grid: only lower half, fading upward ──────────────────────────
overlay = Image.new("RGBA", (W, H), (0, 0, 0, 0))
o = ImageDraw.Draw(overlay)
GRID = 96
LINE = (122, 200, 235)

for gy in range(int(H*0.50)//GRID*GRID, H+1, GRID):
    t = (gy - H*0.50) / (H*0.50)          # 0 at mid, 1 at bottom
    a = int(26 * max(0.0, t))             # max ~10% alpha at bottom
    if a > 0:
        o.line([(0, gy), (W, gy)], fill=LINE + (a,), width=1)

for gx in range(0, W+1, GRID):
    # vertical lines drawn as gradient segments (stronger at bottom)
    for seg_y in range(int(H*0.50), H, 24):
        t = (seg_y - H*0.50) / (H*0.50)
        a = int(20 * max(0.0, t))
        if a > 0:
            o.line([(gx, seg_y), (gx, min(seg_y+24, H))], fill=LINE + (a,), width=1)

img = Image.alpha_composite(img.convert("RGBA"), overlay).convert("RGB")

# ── 4. Vignette: gently darken edges ─────────────────────────────────────────
vmask = Image.new("L", (W, H), 0)
vd = ImageDraw.Draw(vmask)
vd.ellipse([-W*0.25, -H*0.35, W*1.25, H*1.35], fill=255)
vmask = vmask.filter(ImageFilter.GaussianBlur(220))
black = Image.new("RGB", (W, H), (2, 4, 9))
img = Image.composite(img, black, vmask)

# ── Save + apply ──────────────────────────────────────────────────────────────
img.save(OUT, "PNG", optimize=False)
print(f"[wallpaper] saved: {OUT}")

try:
    subprocess.Popen(["swaymsg", f"output * bg {OUT} fill"],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
except FileNotFoundError:
    pass   # build chroot / no compositor — wallpaper applied at login instead
