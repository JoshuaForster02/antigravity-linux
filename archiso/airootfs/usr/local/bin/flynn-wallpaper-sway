#!/usr/bin/env python3
"""Flynn OS — Wallpaper · Ice Grid
Graphite gradient, a single ice horizon line, the identity-disc glyph,
faint reflection lines below the horizon. Minimal. Unmistakable.
"""
import subprocess, sys, os

OUT = "/root/.config/sway/tron-bg.png"
os.makedirs(os.path.dirname(OUT), exist_ok=True)

try:
    from PIL import Image, ImageDraw, ImageFilter, ImageChops
except ImportError:
    print("[wallpaper] PIL not available — using solid color fallback")
    try:
        subprocess.Popen(["swaymsg", "output * bg #0a0b10 solid_color"],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except FileNotFoundError:
        pass
    sys.exit(0)

W, H = 1920, 1080
TOP, MID, BOT = (7, 8, 12), (15, 17, 24), (10, 11, 16)

# ── 1. Base gradient ──────────────────────────────────────────────────────────
img = Image.new("RGB", (W, H))
d = ImageDraw.Draw(img)
for y in range(H):
    t = y / H
    if t < 0.62:
        f = t / 0.62
        c = tuple(int(TOP[i] + (MID[i] - TOP[i]) * f) for i in range(3))
    else:
        f = (t - 0.62) / 0.38
        c = tuple(int(MID[i] + (BOT[i] - MID[i]) * f) for i in range(3))
    d.line([(0, y), (W, y)], fill=c)

# ── 2. Horizon glow ───────────────────────────────────────────────────────────
hy = int(H * 0.62)
glow = Image.new("RGB", (W, H), (0, 0, 0))
g = ImageDraw.Draw(glow)
g.line([(0, hy), (W, hy)], fill=(60, 110, 135), width=2)
g.ellipse([W * 0.30, hy - 44, W * 0.70, hy + 44], fill=(26, 48, 60))
glow = glow.filter(ImageFilter.GaussianBlur(60))
img = ImageChops.add(img, glow)

# ── 3. Crisp horizon line + identity disc glyph ──────────────────────────────
d = ImageDraw.Draw(img)
d.line([(int(W * 0.06), hy), (int(W * 0.94), hy)], fill=(150, 210, 235), width=1)
cx, cy, r = W // 2, hy, 54
d.ellipse([cx - r, cy - r, cx + r, cy + r], outline=(170, 222, 245), width=2)
r2 = int(r * 0.62)
d.ellipse([cx - r2, cy - r2, cx + r2, cy + r2], outline=(170, 222, 245), width=2)
d.line([(cx - int(r * 0.30), cy), (cx + int(r * 0.30), cy)], fill=(170, 222, 245), width=2)

# ── 4. Faint reflection lines below horizon ──────────────────────────────────
ov = Image.new("RGBA", (W, H), (0, 0, 0, 0))
o = ImageDraw.Draw(ov)
for gx in range(0, W + 1, 160):
    for sy in range(hy + 8, H, 18):
        t = (sy - hy) / (H - hy)
        a = int(16 * (1 - t))
        if a > 0:
            o.line([(gx, sy), (gx, sy + 9)], fill=(150, 210, 235, a))
img = Image.alpha_composite(img.convert("RGBA"), ov).convert("RGB")

# ── 5. Vignette ───────────────────────────────────────────────────────────────
vm = Image.new("L", (W, H), 0)
vd = ImageDraw.Draw(vm)
vd.ellipse([-W * 0.25, -H * 0.35, W * 1.25, H * 1.35], fill=255)
vm = vm.filter(ImageFilter.GaussianBlur(200))
img = Image.composite(img, Image.new("RGB", (W, H), (3, 4, 7)), vm)

# ── Save + apply ──────────────────────────────────────────────────────────────
img.save(OUT, "PNG", optimize=False)
print(f"[wallpaper] saved: {OUT}")

try:
    subprocess.Popen(["swaymsg", f"output * bg {OUT} fill"],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
except FileNotFoundError:
    pass   # build chroot / no compositor — wallpaper applied at login instead
