#!/usr/bin/env python3
"""Flynn OS — TRON Grid Wallpaper Generator für Sway/Wayland"""
import subprocess, sys, os, math, random

OUT = "/root/.config/sway/tron-bg.png"
os.makedirs(os.path.dirname(OUT), exist_ok=True)

try:
    from PIL import Image, ImageDraw
    W, H = 1920, 1080
    img = Image.new("RGB", (W, H), (0, 8, 16))
    d   = ImageDraw.Draw(img)

    # Grid lines
    GRID = 80
    for x in range(0, W, GRID):
        alpha = 30 if x % (GRID*4) != 0 else 60
        d.line([(x,0),(x,H)], fill=(0, int(alpha*2.2), int(alpha*2.8)), width=1)
    for y in range(0, H, GRID):
        alpha = 30 if y % (GRID*4) != 0 else 60
        d.line([(0,y),(W,y)], fill=(0, int(alpha*2.2), int(alpha*2.8)), width=1)

    # Intersection dots
    for x in range(0, W, GRID):
        for y in range(0, H, GRID):
            if random.random() < 0.15:
                d.ellipse([x-2,y-2,x+2,y+2], fill=(0,120,150))

    # Energy traces (random horizontal lines)
    random.seed(42)
    for _ in range(18):
        y   = random.randint(0, H)
        x1  = random.randint(0, W//2)
        x2  = random.randint(W//2, W)
        d.line([(x1,y),(x2,y)], fill=(0, 229, 255), width=1)

    # Glow dots on traces
    for _ in range(60):
        x = random.randint(0, W)
        y = random.randint(0, H)
        r = random.randint(1, 3)
        d.ellipse([x-r,y-r,x+r,y+r], fill=(0,200,220))

    img.save(OUT, "PNG")
    print(f"Wallpaper saved: {OUT}")
except ImportError:
    # Fallback: swaybg solid color (no PIL)
    print("PIL not available, using solid background")
    sys.exit(1)

# Apply via swaybg
subprocess.Popen(["pkill", "swaybg"])
import time; time.sleep(0.2)
subprocess.Popen(["swaybg", "-o", "*", "-i", OUT, "-m", "fill"])
