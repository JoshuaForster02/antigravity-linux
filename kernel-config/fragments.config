# Flynn OS Linux — Kernel Config Fragments
# Applied on top of x86_64_defconfig

# ── Display / GPU ─────────────────────────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_AMDGPU=y          # AMD GPU (RDNA1/2/3)
CONFIG_DRM_RADEON=y          # older AMD
CONFIG_DRM_I915=y            # Intel
CONFIG_DRM_NOUVEAU=y         # Nvidia (open)
CONFIG_FB=y
CONFIG_FB_VESA=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# ── Sound ─────────────────────────────────────────────────────────────────────
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=y       # most modern sound cards
CONFIG_SND_USB_AUDIO=y
CONFIG_SND_PCSP=y            # PC speaker (boot chime)

# ── Input ─────────────────────────────────────────────────────────────────────
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y

# ── Network (for PXE + sync) ──────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_NET_CORE=y
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_R8169=y               # Realtek (common on gaming PCs)
CONFIG_ATL1C=y               # Atheros

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=y            # better for gaming (CoW, snapshots)
CONFIG_TMPFS=y
CONFIG_SQUASHFS=y            # for live ISO
CONFIG_OVERLAY_FS=y          # for live ISO + persistence
CONFIG_NFS_FS=y              # for PXE boot over network
CONFIG_NTFS3_FS=y            # read Windows NTFS partitions

# ── Gaming essentials ─────────────────────────────────────────────────────────
CONFIG_FUTEX=y               # required for Proton/Wine
CONFIG_INOTIFY_USER=y
CONFIG_MEMFD_CREATE=y
CONFIG_USERFAULTFD=y         # Wine needs this
CONFIG_VSYSCALL_EMULATE=y    # some old games need this

# ── Power + Performance ───────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_HZ_1000=y             # 1000Hz for gaming

# ── USB ───────────────────────────────────────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y

# ── Trim boot messages ────────────────────────────────────────────────────────
CONFIG_QUIET_PRINTK=y
# CONFIG_BOOT_PRINTK_DELAY is not set
